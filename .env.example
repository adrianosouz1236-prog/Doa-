# .env.example
# Copie este arquivo para .env e preencha com suas configurações

# Flask
SECRET_KEY=sua-chave-secreta-aqui
DEBUG=True
HOST=0.0.0.0
PORT=5000
FLASK_ENV=development

# JWT
JWT_SECRET_KEY=jwt-chave-secreta-mude
JWT_EXPIRES_HOURS=2

# Banco de Dados
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=doacoes_db

# Segurança
BCRYPT_ROUNDS=12

# Rate Limiting
RATELIMIT_DEFAULT=100 per minute
RATELIMIT_STORAGE_URL=memory://

# CORS
CORS_ORIGINS=*

# Logs
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Google Maps API
GOOGLE_MAPS_API_KEY=SUA_CHAVE_AQUI